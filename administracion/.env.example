# ════════════════════════════════════════════════════════════════════
#  Panel de Administración Nexus Core — variables de entorno
#  Defínelas en Vercel → Project → Settings → Environment Variables
#  (Production y, si lo usas, Preview). Tras cambiarlas: Redeploy.
# ════════════════════════════════════════════════════════════════════

# ── OBLIGATORIAS ────────────────────────────────────────────────────

# URL del servidor de licencias ya desplegado en Vercel (sin barra final).
# Es el proyecto license-server. El panel actúa como proxy hacia esta URL.
LICENSE_SERVER_URL="https://nexuscore-iota.vercel.app"

# Clave Bearer de los endpoints /api/admin/* del servidor de licencias.
# DEBE ser EXACTAMENTE la misma NEXUS_ADMIN_API_KEY del license-server.
# Vive SOLO en el servidor (estas funciones). NUNCA se expone al navegador.
NEXUS_ADMIN_API_KEY="pega_aqui_la_misma_clave_admin_del_license_server"

# Contraseña para entrar al panel (la que tú escribes en la pantalla de login).
# Elige una larga y única. Puedes generarla con:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_PANEL_PASSWORD="cambia_esto_por_una_contrasena_larga"

# Secreto para firmar (HMAC) la cookie de sesión del panel.
# Genera uno aleatorio:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PANEL_SESSION_SECRET="cambia_esto_por_un_secreto_aleatorio_de_64_hex"

# ── OPCIONALES ──────────────────────────────────────────────────────

# Duración de la sesión del panel en horas (default 12, máx 168 = 7 días).
# PANEL_SESSION_HOURS=12

# Umbral en días para marcar una licencia como "por vencer" en el dashboard
# (default 30).
# PANEL_EXPIRING_SOON_DAYS=30
