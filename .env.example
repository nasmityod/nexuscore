# ──────────────────────────────────────────────────────────────────────────────
# Nexus-Core — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Seguridad JWT ────────────────────────────────────────────────────────────
# Secreto mínimo de 48 bytes (96 hex). Genera uno con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO_Y_ALEATORIO

# Tiempo de vida del access token (formato ms/jsonwebtoken): 12h, 24h, 7d...
JWT_EXPIRES_IN=12h

# ─── Base de datos PostgreSQL del sistema ─────────────────────────────────────
# Nexus-Core se conecta a un PostgreSQL ya instalado en el sistema operativo.
# Asegúrate de que el servicio de Windows (postgresql-x64-XX) esté en ejecución
# antes de iniciar la app. Comprobar en: services.msc
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=nexuscore
PG_USER=postgres
PG_PASSWORD=CAMBIA_ESTO_POR_TU_PASSWORD_POSTGRES

# Pool de conexiones
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000
PG_CONNECTION_TIMEOUT_MS=10000

# TLS para PostgreSQL (false en instalaciones locales sin certificado)
PG_SSL=false
# PG_SSL_REJECT_UNAUTHORIZED=true

# Alternativa: cadena de conexión completa (sobreescribe variables PG_* individuales)
# DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/nexuscore

# ─── Servidor Express ─────────────────────────────────────────────────────────
PORT=3000

# Entorno: development | production
NODE_ENV=development

# ─── Asistente de primera ejecución (Electron) ────────────────────────────────
# En producción la configuración de PostgreSQL se guarda en userData/config.env.
# NEXUS_FORCE_SETUP=1 fuerza el asistente al arrancar (pruebas o reconfiguración).
# NEXUS_FORCE_SETUP=1
# NEXUS_DEVTOOLS=1 abre DevTools en el .exe instalado (pruebas de producción). F12 alterna.
# NEXUS_DEVTOOLS=1

# ─── Rutas opcionales para respaldos ──────────────────────────────────────────
# Normalmente electron/main.js define NEXUS_BACKUP_DIR automáticamente.
# Respaldos (pg_dump): Nexus detecta automáticamente el binario en
# Program Files\PostgreSQL\<versión>\bin (misma versión mayor que el servidor).
# Solo define estas variables si la detección falla o usas una ruta no estándar:
# NEXUS_BACKUP_DIR=C:\Users\TuUsuario\AppData\Roaming\nexus-core\backups
# NEXUS_PG_BIN_DIR=C:\Program Files\PostgreSQL\18\bin
# NEXUS_PG_DUMP=C:\Program Files\PostgreSQL\18\bin\pg_dump.exe

# Opcional: fuerza el intervalo del respaldo automático periódico (pg_dump) en MINUTOS.
# 0 = programa periódico apagado (siguen valiendo cierre de caja / salir de la app / manual).
# Si no se define, Nexus usa las claves backup_automatico y backup_intervalo_horas en tabla configuracion (Configuración → Respaldo).
# NEXUS_BACKUP_INTERVAL_MINUTES=240

# ─── Tasa BCV automática (dolarapi) ───────────────────────────────────────────
# URL pública en backend/services/bcvTasaAutoService.js; aplica la tasa solo a las 00:00
# del día fecha valor (America/Caracas), según normativa BCV. La tasa USD sigue manual.
# true | false — si no se define, se usa la clave tasa_bcv_auto_activo en configuracion (UI).
# Consulta la API 1×/día (~17:30 Caracas) y aplica la tasa a medianoche (sin variable de intervalo).
# NEXUS_TASA_BCV_AUTO=true

# ─── Licencia Ed25519 (opcional en backend local) ─────────────────────────────
# Si la clave pública embebida en el código no coincide con la privada en Vercel,
# pega aquí la pareja correcta (sin subir .env a Git):
# NEXUS_LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMCow...\n-----END PUBLIC KEY-----"

# Servidor de licencias (admin): generar códigos de prueba con scripts/generar-trial.js
NEXUS_LICENSE_ADMIN_URL=https://tu-app.vercel.app
NEXUS_ADMIN_API_KEY=tu-clave-admin-aqui
