# ── OBLIGATORIAS: definir en Vercel → Settings → Environment Variables ──

# Clave PRIVADA Ed25519 (generada con scripts/generarClaves.js)
# Usar exactamente el formato PEM con \n literales en Vercel.
# NUNCA compartir ni commitear este valor.
NEXUS_LICENSE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMC4C...\n-----END PRIVATE KEY-----"

# Clave de autenticación para los endpoints admin (mínimo 40 caracteres aleatorios)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXUS_ADMIN_API_KEY="cambia_esto_por_una_clave_aleatoria_larga"

# Secreto HMAC para firmar los códigos de venta generados
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SEPARADO de la clave Ed25519 — si uno se filtra el otro sigue protegiendo.
NEXUS_CODE_SECRET="cambia_esto_por_otro_secreto_aleatorio"

# Horas de la licencia de prueba cuando el código tiene esTrial (activación en Vercel). Default 24. Máximo 720.
# NEXUS_TRIAL_HOURS=24

# ── Sistema profesional de licencias (license-key NXCS) ──
# Período de gracia offline en DÍAS: el cliente puede operar sin verificar online hasta este
# límite; pasado, exige reconexión. Default 7, máximo 90.
# NEXUS_GRACE_PERIOD_DAYS=7

# ── Opción A: Redis REST (Upstash) — preferida (@upstash/redis)
KV_REST_API_URL="https://xxxx.upstash.io"
KV_REST_API_TOKEN="..."
# UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN (equivalente)

# ── Opción B: Redis TCP (redis://) — Redis Cloud / muchas integraciones Vercel
# Si defines KV_REST_API_* y KV_REDIS_URL a la vez, gana REST.
# KV_REDIS_URL="redis://default:PASSWORD@host:port"
# REDIS_URL="redis://..."  (alias)

# ── Panel de administración integrado (public/ → /, BFF en /api/panel/*) ──
# Contraseña para entrar al panel web (pantalla de login en la raíz del deploy).
# Generar: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
ADMIN_PANEL_PASSWORD="cambia_esto_por_una_contrasena_larga"

# Secreto HMAC para firmar la cookie de sesión del panel (≥ 32 bytes hex).
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PANEL_SESSION_SECRET="cambia_esto_por_un_secreto_aleatorio_de_64_hex"

# Duración de sesión del panel en horas (default 12, máx 168).
# PANEL_SESSION_HOURS=12

# Umbral "por vencer" en el dashboard (días, default 30).
# PANEL_EXPIRING_SOON_DAYS=30

# URL pública del license-server. Recomendada en Vercel: evita llamadas al hostname
# interno del deploy (VERCEL_URL) que puede tener Deployment Protection.
# LICENSE_SERVER_URL="https://nexuscore-iota.vercel.app"
